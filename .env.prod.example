# Domains
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com

# Registry images (tag explicitly — no :latest in prod)
API_IMAGE=ghcr.io/you/pingdan-api:v0.1.0
WEB_IMAGE=ghcr.io/you/pingdan-web:v0.1.0

# Secrets
POSTGRES_PASSWORD=change-me-long-random
JWT_SECRET=change-me-long-random

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email alerts via Resend (optional) — https://resend.com
# EMAIL_FROM must be on a Resend-verified domain.
RESEND_API_KEY=
EMAIL_FROM=alerts@example.com

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
